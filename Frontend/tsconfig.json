{
  "compilerOptions": {
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "target": "ES2022",
    "lib": ["es2022", "dom"],
    "skipLibCheck": true,
    "noImplicitAny": false
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue"
  ],
  "exclude": ["node_modules"]
}
